{
  "name": "saldos",
  "version": "1.0.0",
  "description": "API para procesamiento de saldos contables",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && prisma generate",
    "start": "tsx src/main.ts",
    "debug:api": "node --inspect=9229 --enable-source-maps --import tsx src/main.ts",
    "dev:api": "tsx watch src/api/server.ts",
    "setup:api-key": "tsx scripts/generateApiKey.ts",
    "bench:bulk-update": "tsx scripts/benchmarkBulkUpdate.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "docker:build": "docker build -t saldos-api:latest .",
    "docker:run": "docker run -p 3000:3000 --env-file .env saldos-api:latest"
  },
  "keywords": [
    "saldos",
    "contabilidad",
    "mysql"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@fastify/type-provider-json-schema-to-ts": "^4.0.0",
    "@prisma/client": "^6.0.0",
    "fastify": "^5.0.0",
    "pino": "^9.0.0",
    "pino-http": "^10.0.0",
    "pino-roll": "^2.0.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "2.1.9",
    "prisma": "^6.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
