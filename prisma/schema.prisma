// This is your Prisma schema file,
// learn more about writing schemas in https://pris.ly/d/prisma-schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model MovimientoContable {
  id                     BigInt   @id @default(autoincrement()) @map("id") @db.UnsignedBigInt
  consecutivo            Int      @default(0) @map("consecutivo")
  estado                 String   @default("APROBADO") @map("estado") @db.VarChar(255)
  fecha                  DateTime @map("fecha") @db.DateTime(0)
  comprobanteId          BigInt?  @map("comprobante_id") @db.UnsignedBigInt
  documento              String?  @map("documento") @db.VarChar(255)
  usuarioCreacionId      BigInt?  @map("usuariocreacion_id") @db.UnsignedBigInt
  usuarioModificacionId  BigInt?  @map("usuariomodificacion_id") @db.UnsignedBigInt
  periodoId              BigInt?  @map("periodo_id") @db.UnsignedBigInt
  libroContableId        BigInt?  @map("librocontable_id") @db.UnsignedBigInt
  cerrado                Boolean  @default(false) @map("cerrado")
  createdAt              DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt              DateTime? @map("updated_at") @db.Timestamp(0)

  @@map("movimiento_contable")
}

model MovimientoContableCuenta {
  id                  BigInt   @id @default(autoincrement()) @map("id") @db.UnsignedBigInt
  movimientoContableId BigInt  @map("movimientocontable_id") @db.UnsignedBigInt
  cuentaContableId    BigInt   @map("cuentacontable_id") @db.UnsignedBigInt
  terceroId           BigInt?  @map("tercero_id") @db.UnsignedBigInt
  centroCostoId       BigInt?  @map("centrocosto_id") @db.UnsignedBigInt
  libroContableId     BigInt?  @map("librocontable_id") @db.UnsignedBigInt
  unidadNegocioId     BigInt?  @map("unidadnegocio_id") @db.UnsignedBigInt
  centroOperacionId   BigInt?  @map("centrooperacion_id") @db.UnsignedBigInt
  categorizacionId    BigInt?  @map("categorizacion_id") @db.UnsignedBigInt
  modeloCartera       String?  @map("modelocartera") @db.VarChar(255)
  modeloCarteraId     BigInt?  @map("modelocartera_id")
  conceptoTributarioId BigInt? @map("conceptotributario_id") @db.UnsignedBigInt
  base                Decimal  @default(0.00) @map("base") @db.Decimal(18, 2)
  debito              Decimal  @default(0.00) @map("debito") @db.Decimal(18, 2)
  credito             Decimal  @default(0.00) @map("credito") @db.Decimal(18, 2)
  trm                 Decimal  @default(0.000000) @map("trm") @db.Decimal(18, 6)
  factorConversion    Decimal  @default(0.000000) @map("factorconversion") @db.Decimal(18, 6)
  createdAt           DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt           DateTime? @map("updated_at") @db.Timestamp(0)

  @@map("movimiento_contable_cuentas")
}

model SaldoContable {
  id                  BigInt   @id @default(autoincrement()) @map("id") @db.UnsignedBigInt
  periodoId           BigInt   @map("periodo_id") @db.UnsignedBigInt
  class               String?  @map("class") @db.VarChar(255)
  entidadId           BigInt?  @map("entidad_id")
  terceroId           BigInt?  @map("tercero_id") @db.UnsignedBigInt
  cuentaContableId    BigInt?  @map("cuentacontable_id") @db.UnsignedBigInt
  centroCostoId       BigInt?  @map("centrocosto_id") @db.UnsignedBigInt
  libroContableId     BigInt?  @map("librocontable_id") @db.UnsignedBigInt
  unidadNegocioId     BigInt?  @map("unidadnegocio_id") @db.UnsignedBigInt
  centroOperacionId   BigInt?  @map("centrooperacion_id") @db.UnsignedBigInt
  categorizacionId    BigInt?  @map("categorizacion_id") @db.UnsignedBigInt
  modeloCartera       String?  @map("modelocartera") @db.VarChar(255)
  modeloCarteraId     BigInt?  @map("modelocartera_id")
  conceptoTributarioId BigInt? @map("conceptotributario_id") @db.UnsignedBigInt
  saldoInicialDebito  Decimal  @default(0.00) @map("saldoinicialdebito") @db.Decimal(18, 2)
  saldoInicialCredito Decimal  @default(0.00) @map("saldoinicialcredito") @db.Decimal(18, 2)
  debito              Decimal  @default(0.00) @map("debito") @db.Decimal(18, 2)
  credito             Decimal  @default(0.00) @map("credito") @db.Decimal(18, 2)
  saldoFinalDebito    Decimal  @default(0.00) @map("saldofinaldebito") @db.Decimal(18, 2)
  saldoFinalCredito   Decimal  @default(0.00) @map("saldofinalcredito") @db.Decimal(18, 2)
  cierre              Boolean  @default(false) @map("cierre")
  createdAt           DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt           DateTime? @map("updated_at") @db.Timestamp(0)

  @@map("saldos_contables")
}
