// This is your Prisma schema file,
// learn more about writing schemas in https://pris.ly/d/prisma-schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model MovimientoContable {
  id                        BigInt       @id @default(autoincrement()) @map("id")
  consecutivo               BigInt       @map("consecutivo")
  estado                    String       @map("estado")
  fecha                     DateTime     @map("fecha")
  comprobanteId             BigInt?      @map("comprobante_id")
  documento                 String?      @map("documento")
  usuarioCreacionId         BigInt?      @map("usuariocreacion_id")
  usuarioModificacionId     BigInt?      @map("usuariomodificacion_id")
  periodoId                 BigInt?      @map("periodo_id")
  libroContableId           BigInt?      @map("librocontable_id")
  cerrado                   Boolean      @default(false) @map("cerrado")
  tipoDocumentoId           BigInt?      @map("tipodocumento_id")
  conceptoTributarioId      BigInt?      @map("conceptotributario_id")
  sucursalId                BigInt?      @map("sucursal_id")
  centroOperacionId         BigInt?      @map("centrooperacion_id")
  tipoMonedaId              BigInt?      @map("tipomoneda_id")
  tipoJornalId              BigInt?      @map("tipojornal_id")
  unidadNegocioId           BigInt?      @map("unidadnegocio_id")
  entidadId                 BigInt?      @map("entidad_id")
  direccionDocumentoId      BigInt?      @map("direcciondocumento_id")
  centroCostoId             BigInt?      @map("centrocosto_id")
  conceptoId                BigInt?      @map("concepto_id")
  valorOperacion            Decimal?     @map("valoroperacion")
  valorNoGenerarRegistro    Decimal?     @map("valornogenerarregistro")
  valorNoAjustarEnTRM       Decimal?     @map("valornnoajustarentrm")
  ivaMesFacturado           String?      @map("ivamesfacturado")
  fechaPago                 DateTime?    @map("fechapago")
  fechaVencimiento          DateTime?    @map("fechavencimiento")
  fechaExpedicion           DateTime?    @map("fechaexpedicion")
  notas                     String?      @map("notas")
  valorDescuento            Decimal?     @map("valordescuento")
  iva                       Decimal?     @map("iva")
  retencion1p               Decimal?     @map("retencion1p")
  retencion2p               Decimal?     @map("retencion2p")
  retencionPropia           Decimal?     @map("retencionpropia")
  retencionExterior         Decimal?     @map("retencionexterior")
  otrosRetenciones          Decimal?     @map("otrosretenciones")
  valorIvaCredito           Decimal?     @map("valorevacredito")
  total                     Decimal?     @map("total")
  tipoContraparteId         BigInt?      @map("tiposcontraparte_id")
  valorTercero              Decimal?     @map("valortercero")
  tipoRegimenFiscalId       BigInt?      @map("tiporregimenfiscal_id")
  regimenFiscal             String?      @map("regimenfiscal")
  tipoContingenciaId        BigInt?      @map("tiposcontingencia_id")
  tipoLugarExpedicionId     BigInt?      @map("tipolugarexpediton_id")
  tipoActoOEventoId         BigInt?      @map("tiposotroevento_id")
  tipoDocumentoOriginarioId BigInt?      @map("tipodocumentooriginario_id")
  tipoDeclaracionId         BigInt?      @map("tipodeclaracion_id")
  fechaActoOEvento          DateTime?    @map("fechaotroevento")
  fechaEfectos              DateTime?    @map("fechaeectos")
  fechaAutorizacion         DateTime?    @map("fechaautorizacion")
  numeroAutorizacion        String?      @map("numerodeautorizacion")
  tipoRegistro              String?      @map("tiporegistro")
  tipoTractamientoId        BigInt?      @map("tipotractamiento_id")
  tipoReteFuenteId          BigInt?      @map("tiporetefuente_id")
  tipoRetePerIvaId          BigInt?      @map("tiporeteperiva_id")
  valorRetRenta             Decimal?     @map("valoretrenta")
  valorRetIva               Decimal?     @map("valoretiva")
  valorRetIiic              Decimal?     @map("valoretiiic")
  valorRetAnticipo          Decimal?     @map("valoretanticipo")
  valorAnticipoPagador      Decimal?     @map("valoretanticipopagador")
  tipoMonedaOperacionId     BigInt?      @map("tipomonedaoperacion_id")
  tipoReteAgenteId          BigInt?      @map("tiporeteagente_id")
  tipoRetencionId           BigInt?      @map("tiporetencion_id")
  numeroContrato            String?      @map("numerodecontrato")
  tipoDocumentoAgregadoId   BigInt?      @map("tipodocumentoagregado_id")
  tipoDocumentoAgregado     String?      @map("tipodocumentoagregado")
  numeroActoConcesionario   String?      @map("numerodeactoconcesionario")
  tipoActoConcesionarioId   BigInt?      @map("tiposotroacto_id")
  fechaActoConcesionario    DateTime?    @map("fechaactoconcesionario")
  numeroResolucion          String?      @map("numerode_resolucion")
  fechaVencimiento2         DateTime?    @map("fechavencimiento2")
  fechaPago2                DateTime?    @map("fechapago2")
  fechaAceptacion           DateTime?    @map("fechaaceptacion")
  fechaEmisionFTE           DateTime?    @map("fechaemisionFTE")
  fechaUltimaActualizacion  DateTime?    @map("fechaUltimaActualizacion")
  numeroRm                  String?      @map("numerode_rm")
  numeroRmAnulado           String?      @map("numerode_rm_anulado")
  fechaUltimaRm             DateTime?    @map("fechaUltima_rm")
  fechaUltimaRmAnulado      DateTime?    @map("fechaUltima_rm_anulado")
  numeroAutorizacionRm      String?      @map("numerodeautorizacion_rm")
  numeroAutorizacionRmAnulado String?    @map("numerodeautorizacion_rm_anulado")
  fechaAutorizacionRm       DateTime?    @map("fechaautorizacion_rm")
  fechaAutorizacionRmAnulado DateTime?   @map("fechaautorizacion_rm_anulado")
  numeroActoConcesionarioRm String?      @map("numerodeactoconcesionario_rm")
  numeroActoConcesionarioRmAnulado String? @map("numerodeactoconcesionario_rm_anulado")
  fechaActoConcesionarioRm  DateTime?    @map("fechaactoconcesionario_rm")
  fechaActoConcesionarioRmAnulado DateTime? @map("fechaactoconcesionario_rm_anulado")
  numeroResolucionRm        String?      @map("numerode_resolucion_rm")
  numeroResolucionRmAnulado String?      @map("numerode_resolucion_rm_anulado")
  fechaVencimiento2Rm       DateTime?    @map("fechavencimiento2_rm")
  fechaVencimiento2RmAnulado DateTime?   @map("fechavencimiento2_rm_anulado")
  fechaPago2Rm              DateTime?    @map("fechapago2_rm")
  fechaPago2RmAnulado       DateTime?    @map("fechapago2_rm_anulado")
  fechaAceptacionRm         DateTime?    @map("fechaaceptacion_rm")
  fechaAceptacionRmAnulado  DateTime?    @map("fechaaceptacion_rm_anulado")
  fechaEmisionFTERm         DateTime?    @map("fechaemisionFTE_rm")
  fechaEmisionFTERmAnulado  DateTime?    @map("fechaemisionFTE_rm_anulado")
  updatedAt                 DateTime?    @map("updated_at")

  cuentas  MovimientoContableCuenta[]
}

model MovimientoContableCuenta {
  id                          BigInt       @id @default(autoincrement()) @map("id")
  movimientoContableId        BigInt       @map("movimientocontable_id")
  cuentaContableId            BigInt       @map("cuentacontable_id")
  terceroId                   BigInt?      @map("tercero_id")
  centroCostoId               BigInt?      @map("centrocosto_id")
  libroContableId             BigInt?      @map("librocontable_id")
  unidadNegocioId             BigInt?      @map("unidadnegocio_id")
  centroOperacionId           BigInt?      @map("centrooperacion_id")
  categorizacionId            BigInt?      @map("categorizacion_id")
  modeloCartera               String?      @map("modelocartera")
  modeloCarteraId             BigInt?      @map("modelocarteraid")
  conceptoTributarioId        BigInt?      @map("conceptotributario_id")
  base                        Decimal      @default(0) @map("base")
  debito                      Decimal      @default(0) @map("debito")
  credito                     Decimal      @default(0) @map("credito")
  trm                         Decimal      @default(0) @map("trm")
  factorConversion            Decimal      @default(0) @map("factorconversion")
  updatedAt                   DateTime?    @map("updated_at")

  movimientoContable          MovimientoContable @relation(fields: [movimientoContableId], references: [id])
}

model SaldoContable {
  id                          BigInt       @id @default(autoincrement()) @map("id")
  periodoId                   BigInt       @map("periodo_id")
  entidadId                   Int?         @map("entidad_id")
  terceroId                   BigInt?      @map("tercero_id")
  cuentaContableId            BigInt?      @map("cuentacontable_id")
  centroCostoId               BigInt?      @map("centrocosto_id")
  libroContableId             BigInt?      @map("librocontable_id")
  unidadNegocioId             BigInt?      @map("unidadnegocio_id")
  centroOperacionId           BigInt?      @map("centrooperacion_id")
  categorizacionId            BigInt?      @map("categorizacion_id")
  modeloCartera               String?      @map("modelocartera")
  modeloCarteraId             BigInt?      @map("modelocarteraid")
  conceptoTributarioId        BigInt?      @map("conceptotributario_id")
  saldoInicialDebito          Decimal      @default(0) @map("saldoinicialdebito")
  saldoInicialCredito         Decimal      @default(0) @map("saldoinicialcredito")
  debito                      Decimal      @default(0) @map("debito")
  credito                     Decimal      @default(0) @map("credito")
  saldoFinalDebito            Decimal      @default(0) @map("saldafinaldebito")
  saldoFinalCredito           Decimal      @default(0) @map("saldafinalcredito")
  cierre                      Boolean      @default(false) @map("cierre")
  updatedAt                   DateTime?    @map("updated_at")

  @@unique([periodoId, entidadId, terceroId, cuentaContableId, centroCostoId, libroContableId, unidadNegocioId, centroOperacionId, categorizacionId, modeloCarteraId, modeloCartera, conceptoTributarioId])
}
